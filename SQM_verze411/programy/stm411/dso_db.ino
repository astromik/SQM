//---------------------------------------------------------------------
// Ke zvolenemu DSO vypocte nektere parametry, ktere se pak pouzivaji v obou metodach vypoctu (GLX i OC)   
// vstupy i vystupy jsou globalni promenne
//  vstupni parametry jsou globalni promenne:
//     uint16_t    vybrany_DSO.RA_dso                        ... rektascenze zvoleneho objektu v setinach stupne (12345 = 123.45 stupnu = 8.23 hod)
//     uint8_t     vybrany_DSO.Dec_dso                       ... deklinace zvoleneho objektu ve stupnich s posunem o 90 stupnu (130 = +40 stupnu; 50 = -40 stupnu)
//     uint16_t    vybrany_DSO.major_dso                     ... velikost hlavni osy DSO objektu v desetinach uhlove minuty  
//     uint16_t    vybrany_DSO.minor_dso                     ... velikost vedlejsi osy DSO objektu v desetinach uhlove minuty  
//     uint16_t    DSO_delka_dalekohledu                     ... ohniskova delka hlavniho zrcadla v mm
//     uint8_t     DSO_delka_okularu                         ... ohniskova delka zvoleneho okularu v mm
//     uint8_t     DSO_schopnosti                            ... stupen  schopnosti pozorovatele 1 az 5, ze ktereho se pocita 'DSO_pozorovatel'
//     float       DSO_zornice_mm                            ... konstanta 7.0 (obvykly prumer zornice oka), neni uzivatelsky editovatelna, ale da se nastavit pred kompilaci programu
//     sada globalnich promennych s datumem, casem a GPS polohou stanoviste pro vypocty azimutu a elevace DSO
// vystupy se nastavuji take jako globalni promenne
//     float       DSO_extinkce                              ... vliv tloustky atmosfery na zaklade elevace objektu
//     float       obecny_azimut                             ... na zaklade rovnikovych souradnic, polohy pozorovatele a casu spocte aktualni azimut objektu
//     float       obecna_elevace                            ... na zaklade rovnikovych souradnic, polohy pozorovatele a casu spocte aktualni elevaci objektu
//     uint8_t     DSO_excentricita                          ... pro zobrazeni hrubeho tvaru na displeji (rozsah hodnot 1 pro uzke objekty az 10 pro kruhove objekty)
//     float       DSO_plocha                                ... plocha objektu spocitana z hlavni a vedlejsi osy jako plocha elipsy v [arcmin2]
//     uint8_t     DSO_stupen_plochy                         ... pro hrube zobrazeni velikosti objektu na displeji v rozsahu 1 pro male objekty az 5 pro velke objekty
//     float       DSO_zvetseni                              ... pomer ohniska hlavniho zrcadla a ohniska zvoleneho okularu
//     float       DSO_delta_SB                              ... vliv dalekohledu
//     float       DSO_pozorovatel                           ... pozorovatele

void spolecne_DSO_vypocty(void)
  {
    // -----  prepocet rovnikovych souradnic na azimut a elevaci ------------
    if (leto == true) casova_zona = letni_posun;
    else              casova_zona = zimni_posun;

    float RaHod = vybrany_DSO.RA_dso / 1500.0;                                      // databazove RA v setinach stupne prepocitat na hodiny
    float DecStup = vybrany_DSO.Dec_dso - 90;                                       // databazove Dec prepocitat na +/- 90 stupnu
    
    zobraz_RTC(false);                                                                         // aktualizace promennych s lokalnim casem 'LOC_...'
    z_LOC_na_Astro_UTC(casova_zona);                                                           // z globalnich promennych pro casove udaje v mistni casove zone (LOC_xxx) vypocte UTC datum a cas
    RaToAzim ( 3 ,    RaHod   ,  DecStup , LOC_rok , LOC_mes , LOC_den , LOC_hod , LOC_min , casova_zona , GeoLon , GeoLat );       // obecne teleso

    obecny_azimut  = round(obecny_azimut);                                                     // zaokrouhleni azimutu na cele stupne
    if (obecny_azimut == 360) obecny_azimut = 0;                                               // osetreni zaokrouhleni tesne pred severem (napriklad 359.7 stupne by se zaokrouhlilo na nesmyslnych 360)
   
    obecna_elevace = round(obecna_elevace);                                                    // zaokrouhleni elevace na cele stupne
    //-----------------------------------------------------------------------

    DSO_zvetseni = DSO_delka_dalekohledu / DSO_delka_okularu;                                  // vypocet dalekohledu podle nastavenych parametru (prumer, ohniska ...)
    float ratio = (DSO_zornice_mm * DSO_zvetseni) / DSO_prumer_dalekohledu;
    DSO_delta_SB = 5.0 * log10(ratio);

    DSO_excentricita = 100 * ((sqrtf(pow(vybrany_DSO.major_dso,2) - pow(vybrany_DSO.minor_dso,2)) / vybrany_DSO.major_dso)+0.005);

    if (DSO_excentricita > 99) DSO_excentricita = 99;

    
    DSO_plocha = (PI *  vybrany_DSO.major_dso * vybrany_DSO.minor_dso) / 400.0;       
  
    if      (DSO_plocha > 1000) DSO_stupen_plochy = 5;               // nejvetsi plocha objeku       - statisticke rozlozeni odpovida asi  25 DSO
    else if (DSO_plocha >   60) DSO_stupen_plochy = 4;               //                                statisticke rozlozeni odpovida asi 185 DSO
    else if (DSO_plocha >   11) DSO_stupen_plochy = 3;               // stredne velka plocha objektu - statisticke rozlozeni odpovida asi 240 DSO
    else if (DSO_plocha >    3) DSO_stupen_plochy = 2;               //                                statisticke rozlozeni odpovida asi 151 DSO
    else                        DSO_stupen_plochy = 1;               // nejmensi plocha objektu      - statisticke rozlozeni odpovida asi  60 DSO

    DSO_extinkce = 1.3 * exp(-0.04 * obecna_elevace);                // vliv tloustky atmosfery (nelinearni podle aktualni elevace) v rozsahu 0 stupnu = 1,3 az 90 stupnu = 0,04

    DSO_pozorovatel = (DSO_schopnosti - 3) * 0.3;                    // prevod ze stupne schopnosti na pridavek/ubytek magnitudy

    // doplnena moznost mirne individualni (kladna nebo zaporna) korekce viditelnosti (napriklad u otevrenych hvezokup, ktere se nachazi na bohatem hvezdnem pozadi)
    uint8_t individualni_stupen = ((vybrany_DSO.typ_dso & 0b11110000) >> 4);        // prevod hornich 4 bitu na cislo 0 az 15

    //                                bit 3 = kladne nebo zaporne znamenko           bity 0 az 3 = absolutni hodnota
    DSO_individualni_korekce = ((individualni_stupen & 0b00001000) ? -1.0 : 1.0) * (individualni_stupen & 0b00000111) * 0.1; 
    
  }
//---------------------------------------------------------------------



//---------------------------------------------------------------------
//  Vypocet stupne viditelnosti DSO pro otevrene hvezdokupy
//
//  vstupni parametry jsou globalni promenne:
//     uint16_t    vybrany_DSO.major_dso                     ... velikost hlavni osy DSO objektu v desetinach uhlove minuty  
//     uint16_t    vybrany_DSO.minor_dso                     ... velikost vedlejsi osy DSO objektu v desetinach uhlove minuty  
//     uint8_t     vybrany_DSO.bs_dso                        ... jas nejjasnejsi hvezdy v hvezdokupe v desetinach magnitudy
//     uint16_t    vybrany_DSO.ns_dso                        ... pocet hvezd v hvezokupe
//     float       DSO_plocha                                ... plocha DSO obektu spoctena z hlavni a vedlejsi osy jako plocha elipsy (v uhlovych minutach)
//     uint16_t    DSO_MSA                                   ... zmereny jas oblohy v tisicinach mag/arcsek2 (kvuli zobrazovani na displeji) priklad 21754 = 21.754 mag/arcsek2
//     float       DSO_pozorovatel                           ... schopnosti pozorovatele
//     float       DSO_extinkce                              ... vliv tloustky atmosfery na zaklade elevace objektu
//     uint8_t     DSO_normal                                ... kalibracni konstanta pro hodnoceni viditelnosti otevrenych hvezdokup v desetinach [mag/arcsek2]
//     uint16_t    DSO_prumer_dalekohledu                    ... prumer dalekohledu v [mm]
//     float       DSO_zornice_mm                            ... konstanta 7.0 (obvykly prumer zornice oka), neni uzivatelsky editovatelna, ale da se nastavit pred kompilaci programu
// Navratova hodnota je stupen viditelnosti 1 az 5

uint8_t vypocet_OC(void)
  {
    float lm_eye =  6.5 + DSO_pozorovatel;                                    // limitni magnituda oka je zavisla na stupni schopnosti pozorovatele
    float lm_scope = lm_eye + (5.0 * log10(DSO_prumer_dalekohledu / DSO_zornice_mm));    // limitni magnituda dalekohledu je zavisla hlavne na prumeru
    lm_scope= lm_scope - ((DSO_normal/10.0) - (DSO_MSA/1000.0));              // Zmerena hodnota jasu MSA je v tisicinach mag/arcsec2, normalovy jas je v desetinach mag/arcsec2
    
    float delta_star = lm_scope - (vybrany_DSO.bs_dso / 10.0);                // Viditelnost nejjasnejsi hvezdy 
    float density = vybrany_DSO.ns_dso / DSO_plocha;                          // Hvezdna hustota
    float densityScore = log10(density);                                      // oko reaguje logaritmicky
    float score = (1.2 * delta_star) + (1.0 * densityScore) - (0.8 * DSO_extinkce) + DSO_pozorovatel;  // celkove skore

    score = score + DSO_individualni_korekce;                                 // zapocteni pripadne individualni korekce

    // DEBUG
    // Serial.print("lm_eye = ");
    // Serial.println(lm_eye,4);
    // Serial.print("lm_scope = ");
    // Serial.println(lm_scope,4);
    // Serial.print("delta_star = ");
    // Serial.println(delta_star,4);
    // Serial.print("density = ");
    // Serial.println(density,4);
    // Serial.print("densityScore = ");
    // Serial.println(densityScore,4);
    // Serial.print("score = ");
    // Serial.println(score,4);

    if (score < -1.5) return 0;                            // prevod 'score' na stupen viditelnosti 
    if (score < -0.8) return 1;
    if (score < -0.2) return 2;
    if (score <  0.5) return 3;
    if (score <  1.2) return 4;
    return 5;
  }
//---------------------------------------------------------------------


//---------------------------------------------------------------------
//  Vypocet stupne viditelnosti DSO pro galaxie, mlhoviny a kulove hvezdokupy
//
//  vstupni parametry jsou globalni promenne:
//     uint16_t    vybrany_DSO.major_dso                     ... velikost hlavni osy DSO objektu v desetinach uhlove minuty  
//     uint16_t    vybrany_DSO.minor_dso                     ... velikost vedlejsi osy DSO objektu v desetinach uhlove minuty  
//     uint8_t     vybrany_DSO.SB_dso                        ... plosny Surface Brightness objektu v desetinach mag/arcmin2   
//     uint8_t     vybrany_DSO.typ_dso                       ... typ objektu (galaxie, mlhovina, hvezdokupa ...)   
//     float       DSO_plocha                                ... plocha DSO obektu spoctena z hlavni a vedlejsi osy jako plocha elipsy (v uhlovych minutach)
//     uint16_t    DSO_MSA                                   ... zmereny jas oblohy v tisicinach mag/arcsek2 (kvuli zobrazovani na displeji) priklad 21754 = 21.754 mag/arcsek2
//     float       DSO_pozorovatel                           ... schopnopsti pozorovatele
//     float       DSO_delta_SB                              ... prinos dalekohledu (okular, prumer, ohnisko)
//     float       DSO_extinkce                              ... vliv tloustky atmosfery na zaklade elevace objektu
//
// Navratova hodnota je stupen viditelnosti 1 az 5

uint8_t vypocet_GLX(void)
  {
    float velikostni_penalizace_velke = 0.6 * log10(sqrtf((vybrany_DSO.minor_dso/10.0) * (vybrany_DSO.major_dso / 10.0)));
    float velikostni_penalizace_male = 0;
   
     if (vybrany_DSO.major_dso < 20 or vybrany_DSO.minor_dso < 20)   // pro objekty pod 2 uhlove minuty v nektere ose se pocita velikostni penalizace 
       {
         velikostni_penalizace_male = 1.2 * log10(2/ sqrtf(DSO_plocha));
       }
              // prictenim 8.89 se prevadi jas z databaze z [mag/arcmin2] na [mag/arcsec2]        = 2.5 * LOG10(60*60)
    float SB_object_eff = (8.89 + (vybrany_DSO.SB_dso / 10.0)) + DSO_delta_SB + DSO_extinkce + velikostni_penalizace_velke + velikostni_penalizace_male;

    float kontrast = (DSO_MSA / 1000.0) - SB_object_eff;
    kontrast = kontrast + DSO_pozorovatel;                        // zapocteni vlivu schopnosti pozorovatele

    switch (vybrany_DSO.typ_dso & 0b00001111)                     // zapocteni vlivu typu DSO (nejvyssi 4 bity obsahuji pripadnou individualni korekci a proto se musi oseknout)
      {
        case 2:                                                   // jasna mlhovina
          kontrast = kontrast + 0.4;
          break;
          
        case 3:                                                   // hvezdokupa + mlhovina
          kontrast = kontrast + 0.2;
          break;
          
        case 4:                                                   // galaxie
          kontrast = kontrast + 0.0;
          break;
  
        case 7:                                                   // planetarni mlhovina
          kontrast = kontrast + 0.6;
          break;

        case 8:                                                   // SN remnant
          kontrast = kontrast + 0.1;
          break;

        default:  
          kontrast = kontrast + 0.0;
        
      }

    kontrast = kontrast + DSO_individualni_korekce;                // zapocteni pripadne individualni korekce


    // DEBUG
    // Serial.print("velikostni_penalizace_velke = ");
    // Serial.println(velikostni_penalizace_velke,4);
    // Serial.print("velikostni_penalizace_male = ");
    // Serial.println(velikostni_penalizace_male,4);
    // Serial.print("SB_object_eff = ");
    // Serial.println(SB_object_eff,4);
    // Serial.print("kontrast (po zapocteni pozorovate, typu objektu a individualni korekce) = ");
    // Serial.println(kontrast,4);

    if      (kontrast < -3.0)  return 0;               // prevod kontrastu na stupnici viditelnosti 0 az 5
    else if (kontrast < -2.3)  return 1;
    else if (kontrast < -1.7)  return 2;
    else if (kontrast < -1.0)  return 3;
    else if (kontrast < -0.3)  return 4;
    else                       return 5;

  }
//---------------------------------------------------------------------



//---------------------------------------------------------------------
// zobrazi viditelnost vcetne informace o problemu pri nulove viditelnosti "ELE-0" 
//  specialni pripad, kdy se viditelnost nepocita, jsou hvezdokupy, ktere nemaji v databazi uveden Surface Brightness
void zobraz_info_viditelnost(void)
  {
    if (DSO_viditelnost < 255)                              // kdyz uz probehlo mereni jasu pozadi a vypocetl se stupen viditelnosti 0 az 5
      {
        if (DSO_viditelnost == 6)
          {
            zobraz_text(129);                               // "ELE-0"
          }
        else
          {
            zobraz_cislo(DSO_viditelnost,0);            
          }
      }
    else                                                    // jeste nebylo zmereno pozadi, proto se stupen viditelnosti nepocita
      {
        zobraz_text(68);                                    // "-----"
      }
  }
