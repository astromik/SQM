
struct DSO_struktura
  {
    uint8_t    typ_dso;               // 1=dvojhvezda, 
                                      // 2=jasna mlhovina (Brt Neb)
                                      // 3=hvezdokupa s mlhovinou(CL+Neb)
                                      // 4=galaxie
                                      // 5=kulova hvezdokupa (Glb CL)
                                      // 6=otevrena hvezdokupa (Opn CL)
                                      // 7=planetarni mlhovina (Pln Neb)
                                      // 8=zbytek po vybuchu supernovy (SN Rem) 
                                      //      nejvyssi 4 bity obsahuji individualni korekci viditelnosti -0.7 az +0.7 mag 
                                      //                 (planovano hlavne pro otevrene hvezdokupy na bohatem hvezdnem pozadi, ktere jsou sice matematicky viditelne dobre, ale tezko se rozlisuji od okoli)

    uint16_t   RA_dso;                // rektascenze objektu zaokrouhlena na setiny stupne 0 az 360 stupnu = 0 - 36000 (jen pro vypocet polohy nad/pod horiontem)
    uint8_t    Dec_dso;               // deklinace objektu zaokrouhelna na stupne a zvetsena o 90 stupnu, aby se odstranily zaporne hodnoty (-90 az + 90 stupnu = 0 az 180) (jen pro vypocet polohy nad/pod horiontem) 
    uint8_t    mag_dso;               // jas objektu v desetinach magnitudy (pro DSO vzdycky kladne)
    uint8_t    SB_dso;                // Surface Brightness v desetinach mag/arcmin2 (plati hlavne pro mlhoviny a galaxie, pro hvezdokupy nebylo uvedeno)
    uint16_t   major_dso;             // hlavni (vetsi) osa v desetinach minuty    (35=3.5' ; 150=15' ; 7=0.7')
    uint16_t   minor_dso;             // vedlejsi osa v desetinach minuty  (35=3.5' ; 150=15' ; 7=0.7')
    uint16_t   ns_dso;                // pocet hvezd v hvezdokupe
    uint8_t    bs_dso;                // jas nejjasnejsi hvezdy v hvezdokupe, nebo centralni hvezdy v planetarni mlhovine v desetinach magnitudy (73 = 7.3 mag) 
  };

