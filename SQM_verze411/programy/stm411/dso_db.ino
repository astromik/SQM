//--------------------------------------------------------------------------------
// zobrazi na displeji slozenou informaci o velikosti plochy a excentricite vybraneho DSO
// promenna 'elipsa' (setiny excentricity) nesmi byt ani po zaokrouhleni vetsi nez 99
void zobraz_tvar(uint8_t plocha , uint8_t elipsa)
  {
    if (plocha > 5)   D_pamet[4] = 8;                           // "_" kdyz je stupen plochy mimo povoleny rozsah (normalne by k tomu dojit nemelo)
    else              D_pamet[4] =  graf_def[plocha];           // cislo, kdyz je stupen plochy v predpokladanem rozsahu 0 az 5

    D_pamet[3] = 64;                                            // druha segmentovka zleva vzdycky oddelovaci pomlcka
    D_pamet[2] = 121 + 128;                                     // prostredni segmentovka vzdycky "E." jako oznaceni excentricity (tecka ma funkci desetinne tecky pro nasledujici dve cifry)

    D_pamet[1] = graf_def[elipsa / 10];                         // druha segmentovka zprava jako desetiny excentricity
    D_pamet[0] = graf_def[elipsa % 10];                         // segmentovka uplne vpravo jako setiny excentricity

    aktualizuj_displej();
  
  }
