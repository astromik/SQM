//--------------------------------------------------------------------------------
// zobrazi na displeji jednu z detailnich informaci vybraneho DSO objektu
//  112=magnituda, 113=hlavni osa .... 119=stupen viditelnosti
//  vsechny parametry z vybraneho objektu z databaze jsou prekopirovane do docasne strukturovane promenne 'vybrany_DSO.xxxx_dso'
//  predpoklada se, ze jsou vypoctene i dalsi globalni promenne ('obecna_elevace', 'obecny_azimut', 'DSO_viditelnost')
void zobraz_detail_dso(uint8_t index_menu_det)
  {
    if (index_menu_det == 113)                                    // magnituda z databaze
      {
        pozice_tecky = 1;                                         // v databazi je hodnota 10x zvetsena, na displeji se musi doplnit desetinna tecka
        zobraz_cislo(vybrany_DSO.mag_dso,0);
      }


    if (index_menu_det == 114)                                    // hlavni osa z databaze
      {
        pozice_tecky = 1;                                         // v databazi je hodnota 10x zvetsena, na displeji se musi doplnit desetinna tecka
        zobraz_cislo(vybrany_DSO.major_dso,0);
      }

    if (index_menu_det == 115)                                    // vedlejsi osa z databaze
      {
        pozice_tecky = 1;                                         // v databazi je hodnota 10x zvetsena, na displeji se musi doplnit desetinna tecka
        zobraz_cislo(vybrany_DSO.minor_dso,0);
      }

    if (index_menu_det == 116)                                    // typ objektu z databaze
      {
        switch(vybrany_DSO.typ_dso & 0b00001111)                  // osekani o pripadne individualni korekce
          {
            case 1:                                               // (dvoj)hvezda
              zobraz_text(128);                                   // "5tAr"
              break;

            case 2:                                               // emisni mlhovina
            case 7:                                               // planetarni mlhovina
            case 8:                                               // zbytek po vybuchu suprnovy
              zobraz_text(123);                                   // "nEbuL"
              break;

            case 3:                                               // hvezdokupa s mlhovinou
              zobraz_text(127);                                   // "cL.nEb"
              break;

            case 4:                                               // galaxie
              zobraz_text(125);                                   // "6ALAH"
              break;

            case 5:                                               // kulova hvezdokupa
              zobraz_text(126);                                   // "6L cL"
              break;

            case 6:                                               // otevrena hvezdokupa
              zobraz_text(124);                                   // "oP cL"
              break;
          }
      }

    if (index_menu_det == 117)                                    // tvar objektu (stupen plochy a excentricita)
      {                                                           //  
        zobraz_tvar(DSO_stupen_plochy,DSO_excentricita);          // na displeji se zobrazi info ve formatu "x-Ey.y" (priklad "3-E0.9" pro stredne velke DSO a temer kruhovity tvar)
      }

    if (index_menu_det == 118)                                    // vypocteny aktualni azimut objektu, zaokrouhleny na cela cisla
      {
        pozice_tecky = 0;        
        zobraz_cislo(obecny_azimut,0);
      }

    if (index_menu_det == 119)                                    // vypoctena aktualni elevace, zaokrouhlena n acela cisla
      {
        pozice_tecky = 0;        
        zobraz_cislo(obecna_elevace,0);
        if (obecna_elevace < 0) DSO_viditelnost = 6;              // neni videt z duvodu objektu pod horizontem
      }


    if (index_menu_det == 120)                                    // pocet hvezd v OC
      {
        pozice_tecky = 0;        
        zobraz_cislo(vybrany_DSO.ns_dso,0);
      }

    if (index_menu_det == 121)                                    // nejjasnejsi hvezda v OC
      {
        pozice_tecky = 1;                                         // v databazi je hodnota 10x zvetsena, na displeji se musi doplnit desetinna tecka
        zobraz_cislo(vybrany_DSO.bs_dso,0);
      }



    if (index_menu_det == 122)
      {
        pozice_tecky = 0;                                         // stupen viditelnosti se zobrazuje jednou cifrou na posledni segmentovce bez desetinne tecky
        zobraz_info_viditelnost();                                // zobrazi viditelnost vcetne informace o problemu pri nulove viditelnosti
      }    
  }



