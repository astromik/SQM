// pro Messierovky plati, ze M = odkaz. V rade nejsou zadne mezery, indexuje se od 1 do 110, proto neni treba delat prevodni tabulku ani celkovy pocet (vzdycky jich bude 110)
//    priklady: M78 odkazuje jednoduse na index "pole_DSO[]" cislo 78
//             M105 odkazuje na index 105 ...




//-------------------- vypocty viditelnosti DSO -------------------
void zobraz_zvolene_dso(uint8_t katalog, uint16_t index_kat)
  {
    bool vypadnout_z_detailu = false;
    bool predchozi_up = HIGH;
    bool predchozi_dn = HIGH;
    bool predchozi_ok = HIGH;
    uint32_t ok_casovani = millis();                                                           // pro mereni delky stisku tlactka OK
    DSO_viditelnost = 255;                                                                     // vysledek podprogramu pro urcovani viditelnosti se po vstupu do podprogramu maze (nastavuje mimo meze). Ke skutecnemu vypoctu dojde az po mereni jasu pozadi.

   
    if (katalog == 0)   DSO_index_DB = index_kat;
    if (katalog == 1)   DSO_index_DB = ngc_odkaz[index_kat][1];
    if (katalog == 2)   DSO_index_DB =  ic_odkaz[index_kat][1];
    // tady odkazuje promenna 'DSO_index_DB' na index hlavni databaze, ve ktere se nachazi zvoleny DSO objekt

    vybrany_DSO = pole_DSO[DSO_index_DB];          // vsechny parametry vybraneho DSO se z databaze prekopiruji do "pracovni" promenne 'vybrany_DSO'

    uint8_t detail_menu_dso = 113;    // pro listovani v detailech se pouzivaji polozky v definicich textu 113 - 122
                                                                                               // [113] magnituda objektu
                                                                                               // [114] delsi rozmer
                                                                                               // [115] kratsi rozmer
                                                                                               // [116] typ objektu
                                                                                               // [117] tvar objektu
                                                                                               // [118] Azimut
                                                                                               // [119] Elevace
                                                                                               // [120] pocet hvezd v OC
                                                                                               // [121] nejjasnejsi hvezda v OC
                                                                                               // [122] stupen viditelnosti


    uint8_t autodet = 113;                                                                        // automaticke cyklovani detailnich informaci ke zvolenemu DSO
    bool popisek = true;                                                                       // jako prvni se zobrazi popisek  ("MAGni") ...
    uint16_t interval_pauzy = 0;                                                               //  ... a zobrazi se okamzite
    uint32_t casovani_automatu = millis();
    uint32_t casovani_autoexit_detailu = millis();


    spolecne_DSO_vypocty();                                                                    // vypocty nekterych parametru DSO objektu do globalnich promennych (plocha, poloha, extinkce, )



    while (digitalRead(pin_tl_ok) == HIGH and digitalRead(pin_tl_up) == HIGH and digitalRead(pin_tl_dn) == HIGH)      // po zvoleni DSO se vsechny detailni informace zacnou stridat 
      {

        interrupty();                                                                          // odskoceni na test, jestli neni nejaky pozadavek o komunikaci, nebo jestli neni cas spustit automaticke mereni    

        if (millis()- casovani_autoexit_detailu > 120000UL)                                    // automaticke cyklovani trva uz moc dlouho, vypadnout do uvodni obrazovky
          {
            vypadnout_z_detailu = true;
            auto_exit_menu = true;
            break;
          }
        if (millis() - casovani_automatu > interval_pauzy)
          {
            if (popisek == true)                                                               // pri promenne popisek=true se zobrazi popis detailu
              {
                zobraz_text(autodet);                                                          // ("MA6ni", "MAJor", "Minor" ... "Vidit")
                interval_pauzy = 900;                                                          // jak dlouho bude svitit popisek, nez se prepise jeho hodnotou
                casovani_automatu = millis();
                popisek = false;                                                               // priste se bude zobrazovat hodnota
              }
            else
              {
                zobraz_detail_dso(autodet);                                                    // zobrazeni hodnoty k predchozimu popisku
                autodet ++;                                                                    // priprava na prepnuti na dalsi detailni informace
                if (autodet > 122) autodet = 113;                                              // po prekroceni maxima se zacina zase od "MA6ni" ( index 113)
                interval_pauzy = 1500;                                                         // jak dlouho bude svitit hodnota, nez se prepise nasledujicim popiskem
                casovani_automatu = millis();
                popisek = true;                                                                // priste se bude zobrazovat popisek
              }
          }
      }                                                                                        // z automatickeho cyklovani se vypadne stiskem libovolneho tlacitka
    
    delay(50);
    
    while (vypadnout_z_detailu == false)
      {
        // listovani v detailech DSO se neprovadi zrychlene, ale vzdycky jen na 1 klik (v okamziku stisku se zobrazi textovy popis, pri uvolneni se zobrazi prislusna hodnota)

        if (digitalRead(pin_tl_dn) == LOW and predchozi_dn == HIGH)                            // prave bylo stisknuto [DOLU]
          {
            predchozi_dn = LOW;
            casovani_autoexit_detailu = millis();                                              // kazdy stisk tlacitka oddaluje automaticke vypadnuti z menu
            delay(50);
            if(detail_menu_dso > 113) detail_menu_dso--;
            zobraz_text(detail_menu_dso);
          }

        if (digitalRead(pin_tl_dn) == HIGH and predchozi_dn == LOW)                            // prave bylo uvolneno [DOLU]
          {
            predchozi_dn = HIGH;
            delay(50);
            zobraz_detail_dso(detail_menu_dso);
          }

        if (digitalRead(pin_tl_up) == LOW and predchozi_up == HIGH)                            // prave bylo stisknuto [NAHORU]
          {
            predchozi_up = LOW;
            casovani_autoexit_detailu = millis();                                              // kazdy stisk tlacitka oddaluje automaticke vypadnuti z menu
            delay(50);
            if(detail_menu_dso < 122) detail_menu_dso++;
            zobraz_text(detail_menu_dso);
          }

        if (digitalRead(pin_tl_up) == HIGH and predchozi_up == LOW)                            // prave bylo uvolneno [NAHORU]
          {
            predchozi_up = HIGH;
            delay(50);
            zobraz_detail_dso(detail_menu_dso);
          }

        if (digitalRead(pin_tl_ok) == LOW and predchozi_ok == HIGH)                            // prave bylo stisknuto [OK]
          {
            predchozi_ok = LOW;
            casovani_autoexit_detailu = millis();                                              // kazdy stisk tlacitka oddaluje automaticke vypadnuti z menu
            delay(50);
            ok_casovani = millis();
            zobraz_text(68);                                                                   // "----"
          }

        if (digitalRead(pin_tl_ok) == LOW and predchozi_ok == LOW and (millis() - ok_casovani > 1000))     // trvani stisku OK trva delsi dobu, bude se merit jas
          {
            zobraz_text(8);                                                                    // "JA5  "
          }



        if (digitalRead(pin_tl_ok) == HIGH and predchozi_ok == LOW)                            // prave bylo uvolneno [OK]
          {
            predchozi_ok = HIGH;
            delay(50);
            if (millis()-ok_casovani > 1000)                                                   // dlouhy stisk [OK] zmeri jas pozadi
              {
                mereni(11);                                                                    // mereni jasu s prumerovanim, ale bez ukladani a vystupu do seriove linky
                DSO_MSA = int_svetlo;                                                          // zmerena hodnota jasu v mmag/arsec2 (v uint16_t formatu)
                               
                pocitej_viditelnost();
                detail_menu_dso = 122;
                zobraz_text(122);                                                              // "Vidit"
                delay(1000);
                zobraz_info_viditelnost();                                                     // zobrazi viditelnost vcetne informace o problemu pri nulove viditelnosti
              }
            else                                                                               // kratky stisk [OK] vypadne z menu detailu DSO
              {
                vypadnout_z_detailu = true;
              }
          }

        interrupty();                                                                          // odskoceni na test, jestli neni nejaky pozadavek o komunikaci, nebo jestli neni cas spustit automaticke mereni    
        
        if (millis() - casovani_autoexit_detailu > 120000UL)                                   // zadne tlacitko se nestisklo uz delsi dobu, vypadne se z podprogramu do hlavni smycky
          {
            vypadnout_z_detailu = true;
            auto_exit_menu = true;
          }
      
      }

  }
